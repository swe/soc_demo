# ── Database ─────────────────────────────────────────────────────────────────
# Local dev (docker compose): postgres://soc:soc@localhost:5432/soc
DATABASE_URL=postgres://soc:soc@localhost:5432/soc

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Base URL of the app (used for callbacks)
AUTH_URL=http://localhost:3000

# Google OIDC (optional — credentials login works without it)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
