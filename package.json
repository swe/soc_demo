{
  "name": "soc-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src tests middleware.ts drizzle.config.ts eslint.config.mjs --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:seed": "tsx src/server/seed/cli.ts",
    "demo:setup": "tsx --env-file-if-exists=.env src/server/seed/demo-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "ci:local": "pnpm typecheck && pnpm lint && pnpm test:unit && pnpm db:migrate && pnpm test:integration"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@headlessui/react": "2.2.9",
    "aos": "2.3.4",
    "argon2": "0.44.0",
    "chart.js": "4.5.1",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.45.2",
    "leaflet": "1.9.4",
    "next": "16.2.1",
    "next-auth": "5.0.0-beta.31",
    "postgres": "3.4.9",
    "react": "19.2.4",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "react-leaflet": "5.0.0",
    "uuidv7": "1.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.2.2",
    "@types/aos": "3.0.7",
    "@types/leaflet": "1.9.21",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.1",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
